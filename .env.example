# Canonical site URL for metadata, sitemap, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Quick diagnostic (default: Flow MarTech diagnostic — https://flowproductions.pt/pt/martech)
NEXT_PUBLIC_DIAGNOSTIC_URL=

# Flowi site agent link (default: https://flowproductions.pt)
NEXT_PUBLIC_FLOW_AGENT_URL=

# Optional YouTube video id for hero reel (default: PHBbd0egBp8 — Shorts embed)
NEXT_PUBLIC_HERO_YOUTUBE_ID=

# Analytics (use GTM or GA — not both required; GTM takes precedence if set)
NEXT_PUBLIC_GTM_ID=
# Defaults to G-YJ85SND4WV if unset; set to empty to disable GA on that deploy
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta (Facebook) Pixel — defaults to 1051059133566371 if unset; set to empty to disable
NEXT_PUBLIC_META_PIXEL_ID=

# In-page clinic diagnostic — AI recommendation (Google Gemini)
GEMINI_API_KEY=
# Optional model id (default: gemini-3.1-flash-lite-preview — see https://ai.google.dev/gemini-api/docs/models)
DIAGNOSTIC_AI_MODEL=
